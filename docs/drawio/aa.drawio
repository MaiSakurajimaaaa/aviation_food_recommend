        mxCell id=wr_eq value=w₁ = 0.46 + 0.22(1−sc) + 0.08(1−de)    w₂ = 0.22 + 0.30·de + 0.12·sc    w₃ = 0.16 + 0.26·sc + 0.18·bc style=rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1;fontSize=9;align=center; parent=1 vertex=1
