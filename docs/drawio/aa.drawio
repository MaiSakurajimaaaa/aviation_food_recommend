        mxCell
        mxCell id=prmidm_1 value=口味得分归一化：norm(x) = x(x+2.0) style=rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1;fontSize=9;align=center; parent=1 vertex=1
          mxGeometry x=430 y=394 width=300 height=22 as=geometry 
        mxCell
        mxCell id=prmidm_2 value=漂移增强：driftBoost = max(0, recentPref − historyPref) style=rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1;fontSize=9;align=center; parent=1 vertex=1
          mxGeometry x=430 y=420 width=300 height=22 as=geometry 
        mxCell
