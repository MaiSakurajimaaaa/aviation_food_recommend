        <mxCell id="77OCy2BOyqP9hsc9aD_r-13" value="子模型二: PRMIDM&#xa;偏好漂移+兴趣迁移" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontColor=#000000;" vertex="1" parent="1">
