<mxfile host="Electron" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) draw.io/25.0.2 Chrome/128.0.6613.186 Electron/32.2.5 Safari/537.36" version="25.0.2">
  <diagram name="图3.1 算法架构图" id="algo-arch">
    <mxGraphModel dx="1788" dy="942" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="in_user" value="&lt;font face=&quot;Times New Roman&quot; style=&quot;font-size: 16px;&quot;&gt;用户ID&lt;br&gt;(userId)&lt;/font&gt;" style="whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;rounded=0;fontFamily=Courier New;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="140" y="30" width="180" height="50" as="geometry" />
        </mxCell>
        <mxCell id="in_flight" value="&lt;font face=&quot;Times New Roman&quot; style=&quot;font-size: 16px;&quot;&gt;航班ID&lt;br&gt;(flightId)&lt;/font&gt;" style="whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;rounded=0;fontFamily=Courier New;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="430" y="30" width="180" height="50" as="geometry" />
        </mxCell>
        <mxCell id="in_meal" value="&lt;font style=&quot;font-size: 16px;&quot;&gt;餐次序号&lt;br&gt;(mealOrder)&lt;/font&gt;" style="whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;rounded=0;fontFamily=Courier New;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="770" y="30" width="180" height="50" as="geometry" />
        </mxCell>
        <mxCell id="in_pref" value="&lt;font face=&quot;Times New Roman&quot; style=&quot;font-size: 16px;&quot;&gt;用户偏好&lt;br&gt;(mealType + flavors)&lt;/font&gt;" style="whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;rounded=0;fontFamily=Courier New;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="1040" y="30" width="180" height="50" as="geometry" />
        </mxCell>
        <mxCell id="X-PP3NUSD8h6CKwi4YiW-16" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="title_models" target="prmidm">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="title_models" value="&lt;font face=&quot;Times New Roman&quot; style=&quot;font-size: 18px;&quot;&gt;三子模型并行计算&lt;/font&gt;" style="whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;rounded=0;fontFamily=Courier New;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="100" y="330" width="1200" height="40" as="geometry" />
        </mxCell>
        <mxCell id="pmfup" value="&lt;font face=&quot;Times New Roman&quot; style=&quot;font-size: 16px;&quot;&gt;子模型一：PMFUP&lt;br&gt;Preference Matching from User Profile&lt;br&gt;餐型匹配: 单偏好+0.45 / 多偏好+0.38&lt;br&gt;口味匹配: min(0.35, 0.15 + n*0.10)&lt;br&gt;&lt;i style=&quot;&quot;&gt;S₁ = clamp(0.2 +typeBonus+flavorBonus)&lt;/i&gt;&lt;/font&gt;" style="whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;rounded=0;fontFamily=Courier New;fontSize=11;align=center;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="100" y="400" width="380" height="150" as="geometry" />
        </mxCell>
        <mxCell id="prmidm" value="&lt;font face=&quot;Times New Roman&quot; style=&quot;font-size: 15px;&quot;&gt;子模型二：PRMIDM&lt;br&gt;Preference Drift &amp;amp; Interest Migration&lt;br&gt;近期/历史偏好归一化: x/(x+2.0)&lt;br&gt;漂移增量: clamp(recentPref - historyPref)&lt;br&gt;&lt;i style=&quot;&quot;&gt;S₂=clamp(0.60·recentPref+0.30·driftBoost+ 0.10·dishSignal)&lt;/i&gt;&lt;/font&gt;" style="whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;rounded=0;fontFamily=Courier New;fontSize=11;align=center;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="510" y="400" width="380" height="150" as="geometry" />
        </mxCell>
        <mxCell id="ammbc" value="&lt;font face=&quot;Times New Roman&quot; style=&quot;font-size: 16px;&quot;&gt;子模型三：AMMBC&lt;br&gt;Adaptive Multi-behavior Collaborative&lt;br&gt;余弦相似度 + 收缩因子 (λ=3.0)&lt;br&gt;流行度去偏: 1/(1+ln(1+exp)/6.0)&lt;br&gt;置信度加权：&lt;i style=&quot;&quot;&gt;S₃=clamp(collab·popDebias·confidence)&lt;/i&gt;&lt;/font&gt;" style="whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;rounded=0;fontFamily=Courier New;fontSize=11;align=center;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="920" y="400" width="380" height="150" as="geometry" />
        </mxCell>
        <mxCell id="X-PP3NUSD8h6CKwi4YiW-24" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="step5" target="step6">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="step5" value="&lt;font face=&quot;Times New Roman&quot; style=&quot;font-size: 16px;&quot;&gt;Step 5: 多餐前序惩罚 (mealOrder ≥ 2)&lt;br&gt;相同菜品: S_fused × 0.70          |          相同 mealType: S_fused × 0.85&lt;/font&gt;" style="whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#000000;rounded=0;fontFamily=Courier New;fontSize=12;align=center;" parent="1" vertex="1">
          <mxGeometry x="100" y="760" width="1200" height="55" as="geometry" />
        </mxCell>
        <mxCell id="step6" value="&lt;pre&gt;&lt;font face=&quot;Times New Roman&quot;&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;Step 6: 排序与输出&lt;br&gt;&lt;/font&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;按 fusedScore 降序排列 → 生成可解释标签 (画像匹配 / 口味漂移 / 协同过滤) → 写入 recommendation_log&lt;br&gt;&lt;/font&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;输出：个性化推荐列表 (含得分与可解释标签)&lt;/font&gt;&lt;/font&gt;&lt;/pre&gt;" style="whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;rounded=0;fontFamily=Courier New;fontSize=12;align=center;" parent="1" vertex="1">
          <mxGeometry x="100" y="860" width="1200" height="80" as="geometry" />
        </mxCell>
        <mxCell id="X-PP3NUSD8h6CKwi4YiW-23" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="X-PP3NUSD8h6CKwi4YiW-1" target="step5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="X-PP3NUSD8h6CKwi4YiW-1" value="&lt;pre&gt;&lt;span style=&quot;font-family: &amp;quot;Times New Roman&amp;quot;; font-size: 15px; white-space: normal;&quot;&gt;Step 4: 自适应权重融合&lt;/span&gt;&lt;br style=&quot;font-family: &amp;quot;Times New Roman&amp;quot;; font-size: 15px; white-space: normal;&quot;&gt;&lt;span style=&quot;font-family: &amp;quot;Times New Roman&amp;quot;; font-size: 15px; white-space: normal;&quot;&gt;signalConf = clamp(ln(1+s)/ln15) behavCover = clamp(c/10.0) driftEvid = clamp(d/12.0)&lt;/span&gt;&lt;br style=&quot;font-family: &amp;quot;Times New Roman&amp;quot;; font-size: 15px; white-space: normal;&quot;&gt;&lt;span style=&quot;font-family: &amp;quot;Times New Roman&amp;quot;; font-size: 15px; white-space: normal;&quot;&gt;w₁ = 0.46 + 0.22·(1-signalConf) + 0.08·(1-driftEvid)&lt;/span&gt;&lt;br style=&quot;font-family: &amp;quot;Times New Roman&amp;quot;; font-size: 15px; white-space: normal;&quot;&gt;&lt;span style=&quot;font-family: &amp;quot;Times New Roman&amp;quot;; font-size: 15px; white-space: normal;&quot;&gt;w₂ = 0.22 + 0.30·driftEvid + 0.12·signalConf&lt;/span&gt;&lt;br style=&quot;font-family: &amp;quot;Times New Roman&amp;quot;; font-size: 15px; white-space: normal;&quot;&gt;&lt;span style=&quot;font-family: &amp;quot;Times New Roman&amp;quot;; font-size: 15px; white-space: normal;&quot;&gt;w₃ = 0.16 + 0.26·signalConf + 0.18·behavCover&lt;/span&gt;&lt;br style=&quot;font-family: &amp;quot;Times New Roman&amp;quot;; font-size: 15px; white-space: normal;&quot;&gt;&lt;i style=&quot;font-family: &amp;quot;Times New Roman&amp;quot;; font-size: 15px; white-space: normal;&quot;&gt;S_fused = (w₁·S₁ + w₂·S₂ + w₃·S₃) / (w₁+w₂+w₃)&lt;/i&gt;&lt;br&gt;&lt;/pre&gt;" style="whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;rounded=0;fontFamily=Courier New;fontSize=12;align=center;" vertex="1" parent="1">
          <mxGeometry x="100" y="600" width="1200" height="120" as="geometry" />
        </mxCell>
        <mxCell id="X-PP3NUSD8h6CKwi4YiW-15" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="X-PP3NUSD8h6CKwi4YiW-3" target="title_models">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="X-PP3NUSD8h6CKwi4YiW-3" value="&lt;pre&gt;&lt;span style=&quot;font-family: &amp;quot;Times New Roman&amp;quot;; font-size: 16px; white-space: normal;&quot;&gt;Step 2: 构建交互上下文&lt;/span&gt;&lt;br style=&quot;font-family: &amp;quot;Times New Roman&amp;quot;; font-size: 16px; white-space: normal;&quot;&gt;&lt;span style=&quot;font-family: &amp;quot;Times New Roman&amp;quot;; font-size: 16px; white-space: normal;&quot;&gt;Load ≤5000 logs (180天) → Parse Signals (曝光 0.15 | 点击 2.0 | 预选 5.0 | 评分 1.0~2.0)&lt;/span&gt;&lt;br style=&quot;font-family: &amp;quot;Times New Roman&amp;quot;; font-size: 16px; white-space: normal;&quot;&gt;&lt;span style=&quot;font-family: &amp;quot;Times New Roman&amp;quot;; font-size: 16px; white-space: normal;&quot;&gt;Apply Time Decay: e^(-0.018 * days) → Split Flavor Scores into Recent (30d) &amp;amp; Long (180d)&lt;/span&gt;&lt;br&gt;&lt;/pre&gt;" style="whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;rounded=0;fontFamily=Courier New;fontSize=12;align=center;" vertex="1" parent="1">
          <mxGeometry x="100" y="230" width="1200" height="70" as="geometry" />
        </mxCell>
        <mxCell id="X-PP3NUSD8h6CKwi4YiW-14" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;" edge="1" parent="1" source="X-PP3NUSD8h6CKwi4YiW-4" target="X-PP3NUSD8h6CKwi4YiW-3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="X-PP3NUSD8h6CKwi4YiW-4" value="&lt;pre&gt;&lt;span style=&quot;font-family: &amp;quot;Times New Roman&amp;quot;; font-size: 16px; white-space: normal;&quot;&gt;Step 1: 数据加载与候选筛选&lt;/span&gt;&lt;br style=&quot;font-family: &amp;quot;Times New Roman&amp;quot;; font-size: 16px; white-space: normal;&quot;&gt;&lt;span style=&quot;font-family: &amp;quot;Times New Roman&amp;quot;; font-size: 16px; white-space: normal;&quot;&gt;Cabin Cascade: 头等舱→[1,2,3] | 商务舱→[2,3] | 经济舱→[3]&lt;/span&gt;&lt;br style=&quot;font-family: &amp;quot;Times New Roman&amp;quot;; font-size: 16px; white-space: normal;&quot;&gt;&lt;span style=&quot;font-family: &amp;quot;Times New Roman&amp;quot;; font-size: 16px; white-space: normal;&quot;&gt;SQL Candidate Query: JOIN flight_route_dish, cabin_type IN (...), stock&amp;gt;0, LIMIT 20&lt;/span&gt;&lt;br&gt;&lt;/pre&gt;" style="whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;rounded=0;fontFamily=Courier New;fontSize=12;align=center;" vertex="1" parent="1">
          <mxGeometry x="100" y="120" width="1200" height="70" as="geometry" />
        </mxCell>
        <mxCell id="X-PP3NUSD8h6CKwi4YiW-5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.108;entryY=0.031;entryDx=0;entryDy=0;entryPerimeter=0;" edge="1" parent="1" source="in_user" target="X-PP3NUSD8h6CKwi4YiW-4">
          <mxGeometry relative="1" as="geometry" />
