{
	
	"easycom": {
		"autoscan": true,
		"custom": {
			
			"^uni-(.*)": "@dcloudio/uni-ui/lib/uni-$1/uni-$1.vue"
		}
	},
	"pages": [ 
		{
			"path": "pages/flight/flight",
			"style": {
				"navigationBarTitleText": "航班",
				"navigationBarTextStyle": "white"
			}
		},
		{
			"path": "pages/recommendation/recommendation",
			"style": {
				"navigationBarTitleText": "餐食预选",
				"navigationBarTextStyle": "white"
			}
		},
		{
			"path": "pages/my/my",
			"style": {
				"navigationBarTitleText": "我的"
			}
		},
		{
			"path": "pages/login/login",
			"style": {
				"navigationBarTitleText": "登录页"
			}
		},
		{
			"path": "pages/identity/identity",
			"style": {
				"navigationBarTitleText": "身份核验"
			}
		},
		{
			"path": "pages/index/index",
			"style": {
				"navigationBarTitleText": "首页",
				"navigationBarTextStyle": "white"
			}
		},
		{
			"path": "pages/updateMy/updateMy",
			"style": {
				"navigationBarTitleText": "信息设置"
			}
		},
		{
			"path": "pages/preferences/preferences",
			"style": {
				"navigationBarTitleText": "饮食偏好"
			}
		},
		{
			"path": "pages/recommendConfirm/recommendConfirm",
			"style": {
				"navigationBarTitleText": "确认预选"
			}
		},
		{
			"path": "pages/flightRating/flightRating",
			"style": {
				"navigationBarTitleText": "航班服务评分"
			}
		}
	],

	"tabBar": {
		"color": "#333",
		"selectedColor": "#00aaff",
		"backgroundColor": "#fff",
		"borderStyle": "white",
		"list": [
			{
				"text": "航班",
				"pagePath": "pages/flight/flight",
				"iconPath": "static/tabs/home_default.png",
				"selectedIconPath": "static/tabs/home_selected.png"
			},
			{
				"text": "餐食预选",
				"pagePath": "pages/recommendation/recommendation",
				"iconPath": "static/tabs/cart_default.png",
				"selectedIconPath": "static/tabs/cart_selected.png"
			},
			{
				"text": "评分",
				"pagePath": "pages/flightRating/flightRating",
				"iconPath": "static/tabs/category_default.png",
				"selectedIconPath": "static/tabs/category_selected.png"
			},
			{
				"text": "我的",
				"pagePath": "pages/my/my",
				"iconPath": "static/tabs/user_default.png",
				"selectedIconPath": "static/tabs/user_selected.png"
			}
		]
	},
	"globalStyle": {
		"navigationBarTextStyle": "white",
		"navigationBarTitleText": "uni-app",
		"navigationBarBackgroundColor": "#00aaff",
		"backgroundColor": "#F8F8F8"
	}
}