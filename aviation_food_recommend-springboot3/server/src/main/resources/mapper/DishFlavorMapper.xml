<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="fun.hykgraph.mapper.DishFlavorMapper">

    <!-- dish_flavor table deprecated; flavors now in dish.flavor_tags JSON column -->
    <!-- All methods are no-ops for backward compatibility -->

    <insert id="insertBatch">
        select 1 from dual where 1 = 0
    </insert>

    <select id="getByDishId" resultType="fun.hykgraph.entity.DishFlavor">
        select null as id, null as name, null as list, null as dishId
        from dual where 1 = 0
    </select>

    <delete id="deleteByDishId">
        select 1 from dual where 1 = 0
    </delete>

    <delete id="deleteBatch">
        select 1 from dual where 1 = 0
    </delete>

</mapper>
