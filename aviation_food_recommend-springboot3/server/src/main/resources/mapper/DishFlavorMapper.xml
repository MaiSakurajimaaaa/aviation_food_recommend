<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="fun.hykgraph.mapper.DishFlavorMapper">

    <insert id="insertBatch">
        insert into dish_flavor (name, list, dish_id) VALUES
        <foreach collection="list" item="df" separator=",">
            (#{df.name}, #{df.list}, #{df.dishId})
        </foreach>
    </insert>

    <select id="getByDishId" resultType="fun.hykgraph.entity.DishFlavor">
        select * from dish_flavor where dish_id = #{dishId}
    </select>

    <delete id="deleteByDishId">
        delete from dish_flavor where dish_id = #{dishId}
    </delete>

    <delete id="deleteBatch">
        delete from dish_flavor where dish_id in
        <foreach collection="list" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>
